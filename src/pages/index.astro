---
import Base from '../layouts/Base.astro';
import PublicationEntry from '../components/PublicationEntry.astro';
import { profile, bioHtml } from '../data/profile';
import { publications, publicationYears } from '../data/publications';
import { education } from '../data/education';
import { news } from '../data/news';
import { experience } from '../data/experience';
import { service, talks, teaching } from '../data/activities';

const activityGroups = [
  { label: 'Service', items: service },
  { label: 'Talks', items: talks },
  { label: 'Teaching', items: teaching },
].filter((g) => g.items.length > 0);
---

<Base>
  <h1 class="visually-hidden">{profile.name}</h1>

  <section class="card" id="about">
    <p set:html={bioHtml} style="margin-top:0" />
    <p style="margin-bottom:0">
      Please find my <a href={profile.cv} target="_blank" rel="noopener">CV</a> linked here.
    </p>
  </section>

  {
    news.length > 0 && (
      <section class="card" id="news">
        <h2>News</h2>
        <ul class="news-list">
          {news.map((item) => (
            <li>
              <span class="news-date">{item.date}</span>
              <span class="news-text">
                <Fragment set:html={item.html} />
                {item.link && (
                  <span class="pub-links">
                    <a href={item.link.url} target="_blank" rel="noopener">
                      {item.link.label}
                    </a>
                  </span>
                )}
              </span>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <section class="card" id="publications">
    <h2>Publications</h2>
    <div class="filter-tabs" role="group" aria-label="Filter publications by type">
      <button type="button" class="active" data-filter="all">All</button>
      <button type="button" data-filter="journal">Journal</button>
      <button type="button" data-filter="conference">Conference</button>
    </div>
    {
      publicationYears.map((year) => (
        <div class="pub-group">
          <h3>{year}</h3>
          <ul class="pub-list">
            {publications
              .filter((p) => p.year === year)
              .map((pub) => (
                <PublicationEntry pub={pub} />
              ))}
          </ul>
        </div>
      ))
    }
    <p class="muted" style="margin-bottom:0">
      More publications on <a href={profile.scholar} target="_blank" rel="noopener">Google Scholar</a>.
    </p>
  </section>

  <script>
    const tabs = document.querySelectorAll<HTMLButtonElement>('.filter-tabs button');
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const filter = tab.dataset.filter;
        tabs.forEach((t) => t.classList.toggle('active', t === tab));
        document.querySelectorAll<HTMLElement>('.pub-group').forEach((group) => {
          let visible = 0;
          group.querySelectorAll<HTMLElement>('.pub-list li').forEach((li) => {
            const show = filter === 'all' || li.dataset.type === filter;
            li.hidden = !show;
            if (show) visible++;
          });
          group.hidden = visible === 0;
        });
      });
    });
  </script>

  {
    experience.length > 0 && (
      <section class="card" id="experience">
        <h2>Experience</h2>
        <ul class="edu-list">
          {experience.map((exp) => (
            <li>
              <span class="period">{exp.period}</span>
              {exp.organization}
              <span class="degree">{exp.role}</span>
              {exp.detailHtml && <span class="detail" set:html={exp.detailHtml} />}
              {exp.location && <span class="detail muted">{exp.location}</span>}
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <section class="card" id="education">
    <h2>Education</h2>
    <ul class="edu-list">
      {
        education.map((edu) => (
          <li>
            <span class="period">{edu.period}</span>
            {edu.institution}
            <span class="degree">{edu.degree}</span>
            <span class="detail" set:html={edu.detailHtml} />
          </li>
        ))
      }
    </ul>
  </section>

  {
    activityGroups.length > 0 && (
      <section class="card" id="activities">
        <h2>Service, Talks &amp; Teaching</h2>
        {
          activityGroups.map((group) => (
            <>
              <h3>{group.label}</h3>
              <ul class="news-list">
                {group.items.map((item) => (
                  <li>
                    <span class="news-date">{item.date}</span>
                    <span class="news-text">
                      <Fragment set:html={item.html} />
                      {item.link && (
                        <span class="pub-links">
                          <a href={item.link.url} target="_blank" rel="noopener">
                            {item.link.label}
                          </a>
                        </span>
                      )}
                    </span>
                  </li>
                ))}
              </ul>
            </>
          ))
        }
      </section>
    )
  }
</Base>
