---
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';
import { profile } from '../data/profile';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = profile.name,
  description = 'Youngjun Choi — Ph.D. student at KAIST Total Experience (TX) Lab researching the art and technology of mediated atmospheres.',
} = Astro.props;

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const nav = [
  { label: 'Home', href: '/' },
  { label: 'Publications', href: '/#publications' },
  { label: 'Courses', href: '/courses/' },
  { label: 'Music', href: '/music' },
  { label: 'CV', href: profile.cv },
];
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(profile.photo, Astro.site)} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <nav>
        <a class="brand" href="/">{profile.name}</a>
        {
          nav.map((item) => (
            <a
              href={item.href}
              aria-current={
                currentPath === item.href.replace(/\/$/, '') ? 'page' : undefined
              }
              target={item.href.startsWith('http') ? '_blank' : undefined}
              rel={item.href.startsWith('http') ? 'noopener' : undefined}
            >
              {item.label}
            </a>
          ))
        }
      </nav>
    </header>
    <div class="shell">
      <Sidebar />
      <main>
        <slot />
      </main>
    </div>
    <footer class="site-footer">
      <div class="inner">
        © {year} {profile.name} · Built with <a href="https://astro.build/">Astro</a> ·
        Hosted on <a href="https://pages.github.com/">GitHub Pages</a>
      </div>
    </footer>
  </body>
</html>
